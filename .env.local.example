# Mailchimp Integration
# Get your API key from: https://mailchimp.com/account/api/
# Format: xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx-usXX
MAILCHIMP_API_KEY=your_mailchimp_api_key_here

# Get your List/Audience ID from:
# Mailchimp Dashboard → Audience → All Contacts → Settings → Audience name and defaults
# It looks like: a1b2c3d4e5
MAILCHIMP_LIST_ID=your_audience_list_id_here
