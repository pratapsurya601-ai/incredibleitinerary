# ─── IncredibleItinerary — Environment Variables ───────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.

# ── Pexels API (Smart Auto Images — NO MORE WRONG PHOTOS) ────────────────────
# FREE key — get it in 2 minutes:
# 1. Go to https://www.pexels.com/api/
# 2. Click "Get Started" → sign up → click "Your API Key"
# 3. Copy the key and paste below
PEXELS_API_KEY=your_pexels_api_key_here

# ── WhatsApp ─────────────────────────────────────────────────────────────────
# Replace with your actual WhatsApp number (no + or spaces)
NEXT_PUBLIC_WHATSAPP_NUMBER=91XXXXXXXXXX

# ── Email / Resend ────────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
INQUIRY_EMAIL_TO=your@email.com

# ── Mailchimp (Newsletter) ────────────────────────────────────────────────────
MAILCHIMP_API_KEY=xxxxxxxxxxxxxxxxxxxx-us1
MAILCHIMP_LIST_ID=xxxxxxxxxx
MAILCHIMP_DC=us1

# ── ConvertKit (alternative) ──────────────────────────────────────────────────
# CONVERTKIT_API_KEY=xxxxxxxxxxxxxxxxxxxx
# CONVERTKIT_FORM_ID=xxxxxxxxxx

# ── Affiliate IDs ────────────────────────────────────────────────────────────
# Booking.com affiliate ID (optional — clean URLs generated if missing)
NEXT_PUBLIC_BOOKING_AID=
# Viator partner ID (optional — clean URLs generated if missing)
NEXT_PUBLIC_VIATOR_ID=

# ── Supabase (optional DB for leads) ─────────────────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=xxxx
